generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  guest
  member
  admin
}

enum PaymentStatus {
  paid
  unpaid
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         Role     @default(member)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Judge {
  id             String @id @default(cuid())
  name           String
  avatarUrl      String @map("avatar_url")
  title          String
  country        String
  stars          Int    @default(1)
  phone          String
  email          String
  certifications String
  history        String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("judges")
}

model Member {
  id              String        @id @default(cuid())
  memberCode      String        @unique @map("member_code")
  name            String
  avatarUrl       String        @map("avatar_url")
  country         String
  membershipTier  String        @map("membership_tier")
  expirationDate  DateTime      @map("expiration_date")
  paymentStatus   PaymentStatus @default(unpaid) @map("payment_status")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("members")
}

model Organization {
  id             String @id @default(cuid())
  countryId      String @unique @map("country_id")
  orgName        String @map("org_name")
  logoUrl        String @map("logo_url")
  flagUrl        String @map("flag_url")
  representative String
  address        String
  phone          String
  email          String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("organizations")
}

model NewsItem {
  id        String   @id @default(cuid())
  title     String
  excerpt   String
  imageUrl  String   @map("image_url")
  link      String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("news_items")
}

model Partner {
  id        String @id @default(cuid())
  name      String
  logoUrl   String @map("logo_url")
  sortOrder Int    @default(0) @map("sort_order")

  @@map("partners")
}

model TrainingRegistration {
  id           String   @id @default(cuid())
  fullName     String   @map("full_name")
  organization String
  phone        String
  email        String
  course       String
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("training_registrations")
}

model ContactMessage {
  id        String   @id @default(cuid())
  fullName  String   @map("full_name")
  email     String
  phone     String?
  subject   String
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

model Course {
  id          String @id @default(cuid())
  name        String
  description String
  sortOrder   Int    @default(0) @map("sort_order")

  @@map("courses")
}

enum AppStatus {
  pending
  approved
  rejected
}

model MemberApplication {
  id         String    @id @default(cuid())
  fullName   String    @map("full_name")
  dob        String
  phone      String
  country    String
  experience String
  avatarPath String?   @map("avatar_path")
  resumePath String?   @map("resume_path")
  status     AppStatus @default(pending)
  adminNote  String?   @map("admin_note")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("member_applications")
}

model PartnerCard {
  id          String   @id @default(cuid())
  name        String
  description String
  imageUrl    String   @map("image_url")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("partner_cards")
}
