# ============================================================
# PRODUCTION ENVIRONMENT VARIABLES — Sao chép thành .env.local
# ============================================================

# Supabase PostgreSQL — lấy từ Supabase Dashboard > Settings > Database
# Transaction pooler (dùng cho Vercel serverless):
DATABASE_URL="postgresql://postgres.XXXX:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (dùng cho prisma migrate):
DIRECT_URL="postgresql://postgres.XXXX:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# JWT Secret — đổi thành chuỗi ngẫu nhiên dài 32+ ký tự
JWT_SECRET="THAY_BANG_CHUOI_BI_MAT_NGAU_NHIEN_DAI_32_KY_TU"

# Admin mặc định (dùng khi seed database lần đầu)
ADMIN_EMAIL="admin@worldiacasia.com"
ADMIN_PASSWORD="THAY_BANG_MAT_KHAU_MANH"
